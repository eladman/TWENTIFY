{
  "name": "twentify",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "prebuild": "expo prebuild",
    "typecheck": "tsc --noEmit",
    "generate-assets": "node scripts/generate-assets.js",
    "generate-screenshots": "node app-store/generate-screenshots.js",
    "fix-codegen": "node scripts/fix-codegen.js",
    "pod-install": "node scripts/fix-codegen.js && cd ios && RCT_SKIP_CODEGEN=1 pod install",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo-google-fonts/dm-sans": "*",
    "@expo-google-fonts/ibm-plex-mono": "*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@sentry/react-native": "~7.2.0",
    "@supabase/supabase-js": "^2.97.0",
    "date-fns": "^4.1.0",
    "expo": "^54.0.33",
    "expo-asset": "~12.0.12",
    "expo-auth-session": "~7.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-router": "~6.0.23",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "posthog-react-native": "^4.37.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-mmkv": "^3.2.0",
    "react-native-purchases": "^9.10.3",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0",
    "react-native-worklets": "^0.5.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.10",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "babel-preset-expo": "~54.0.10",
    "canvas": "^3.2.1",
    "eslint": "^10.0.2",
    "jest": "^30.2.0",
    "jest-expo": "~54.0.0",
    "patch-package": "^8.0.1",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "semver": ">=7.6.0",
    "send": ">=0.19.0",
    "fast-xml-parser": ">=5.3.6",
    "minimatch": ">=10.2.1"
  }
